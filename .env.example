# Application
NODE_ENV=development
PORT=8080

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=movies

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS: comma-separated allowed origins. When set, credentials (cookies) are allowed
# only for these origins. Leave blank to reflect any origin without sharing credentials.
CORS_ORIGIN=

# Cache TTL for read endpoints, in milliseconds
CACHE_TTL_MS=60000

# TMDB credential (https://www.themoviedb.org/settings/api)
# Accepts either the 32-char "API Key" or the JWT "API Read Access Token";
# the client detects which one it is and authenticates accordingly.
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
# Base URL of the TMDB image CDN; movie responses expose full posterUrl/backdropUrl built from it
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
# Number of popular-movie pages (20 movies each) synced from TMDB
TMDB_SYNC_PAGES=5

# Auth (tokens are delivered as httpOnly cookies; bearer header also accepted)
JWT_ACCESS_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-too-in-production
JWT_REFRESH_EXPIRES_IN=7d
